{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "ask": [
      "mcp__*Gmail*",
      "mcp__*Google_Drive*",
      "mcp__*Slack*",
      "WebFetch",
      "Bash(git push:*)",
      "Bash(curl:*)",
      "Bash(scp:*)"
    ],
    "deny": []
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Write|Edit|Bash|mcp__.*",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$CLAUDE_PROJECT_DIR/scripts/guardrail-check.sh\""
          }
        ]
      }
    ]
  }
}
